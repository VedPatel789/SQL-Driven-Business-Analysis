<!DOCTYPE html>
<html>
<head>
  <title>SQL Driven Business Analysis</title>

  <!-- SQL.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/sql-wasm.js"></script>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body {
      font-family: Arial;
      margin: 20px;
      background: #f4f4f4;
    }

    h1 { color: #2c3e50; }

    textarea {
      width: 100%;
      height: 100px;
      font-size: 14px;
    }

    button {
      padding: 10px;
      margin-top: 10px;
      cursor: pointer;
    }

    pre {
      background: black;
      color: lime;
      padding: 15px;
      height: 200px;
      overflow: auto;
    }

    canvas {
      background: white;
      margin-top: 20px;
      padding: 10px;
    }
  </style>
</head>

<body>

<h1>SQL Driven Business Analysis Dashboard</h1>

<h3>SQL Query Editor</h3>
<textarea id="sqlInput">
SELECT c.name, SUM(o.total_amount) AS total_spent
FROM customers c
JOIN orders o ON c.customer_id = o.customer_id
GROUP BY c.name;
</textarea>

<button onclick="runQuery()">Run SQL Query</button>

<pre id="output">Result will appear here...</pre>

<canvas id="chart" width="400" height="200"></canvas>

<script>
let db;
let chart;

initSqlJs({
  locateFile: file =>
    `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.8.0/${file}`
}).then(SQL => {

  db = new SQL.Database();

  // ================= DATABASE =================
  db.run(`
    CREATE TABLE customers (
      customer_id INTEGER,
      name TEXT,
      city TEXT
    );

    CREATE TABLE orders (
      order_id INTEGER,
      customer_id INTEGER,
      total_amount INTEGER
    );
  `);

  // ================= DATA =================
  db.run(`
    INSERT INTO customers VALUES
    (1,'Arjun Mehta','Surat'),
    (2,'Priya Sharma','Ahmedabad'),
    (3,'Rohan Patel','Mumbai'),
    (4,'Sneha Joshi','Pune'),
    (5,'Vikram Singh','Delhi'),
    (6,'Neha Verma','Jaipur'),
    (7,'Karan Desai','Vadodara'),
    (8,'Isha Shah','Rajkot'),
    (9,'Aditya Rao','Bangalore'),
    (10,'Meera Nair','Kochi');

    INSERT INTO orders VALUES
    (1,1,75000),
    (2,2,20000),
    (3,3,7000),
    (4,4,25000),
    (5,5,55000),
    (6,6,3000),
    (7,7,20000),
    (8,8,55000),
    (9,9,75000),
    (10,10,25000);
  `);

  document.getElementById("output").innerText =
    "Database Ready! Run SQL query";
});

// ================= RUN QUERY =================
function runQuery() {
  let sql = document.getElementById("sqlInput").value;
  let result = db.exec(sql);

  if (!result.length) {
    document.getElementById("output").innerText = "No result";
    return;
  }

  let cols = result[0].columns;
  let values = result[0].values;

  // ===== TEXT OUTPUT =====
  let output = cols.join(" | ") + "\n--------------------------\n";
  values.forEach(row => {
    output += row.join(" | ") + "\n";
  });

  document.getElementById("output").innerText = output;

  // ===== CHART UPDATE =====
  createChart(cols, values);
}

// ================= CHART =================
function createChart(cols, values) {

  let labels = values.map(r => r[0]);
  let data = values.map(r => r[1]);

  if (chart) chart.destroy();

  chart = new Chart(document.getElementById("chart"), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'SQL Result Visualization',
        data: data,
        backgroundColor: 'rgba(52, 152, 219, 0.7)'
      }]
    }
  });
}
</script>

</body>
</html>
